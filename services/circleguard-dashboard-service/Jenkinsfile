pipeline {
    agent any

    environment {
        DOCKER_REGISTRY  = 'kind-registry:5000'
        IMAGE_NAME       = 'circleguard/dashboard-service'
        IMAGE_TAG        = 'dev'
        DEPLOYMENT_NAME  = 'circleguard-dashboard'
        K8S_NAMESPACE    = 'circleguard-dev'
        K8S_DIR          = 'k8s/services/circleguard-dashboard'
        GRADLE_TARGET    = ':services:circleguard-dashboard-service'
        GRADLE_USER_HOME = '/var/jenkins_home/.gradle'
        PATH             = "/var/jenkins_home/bin:${env.PATH}"
    }

    stages {
        stage('Checkout') {
            steps {
                cleanWs()
                checkout scm
            }
        }

        stage('Build') {
            steps {
                sh './gradlew ${GRADLE_TARGET}:build -x test'
            }
        }

        stage('Unit Test') {
            steps {
                sh './gradlew ${GRADLE_TARGET}:test'
            }
        }

        stage('Docker Build') {
            steps {
                sh 'docker build --network=host -f services/circleguard-dashboard-service/Dockerfile -t ${DOCKER_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG} .'
            }
        }

        stage('Docker Push') {
            steps {
                sh 'docker push ${DOCKER_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}'
            }
        }

        stage('Deploy Dev') {
            steps {
                withKubeConfig([credentialsId: 'kubeconfig-circleguard']) {
                    sh 'kubectl apply -k ${K8S_DIR}/ -n ${K8S_NAMESPACE}'
                    sh 'kubectl rollout restart deployment/${DEPLOYMENT_NAME} -n ${K8S_NAMESPACE}'
                }
            }
        }

        stage('Verify Rollout') {
            steps {
                withKubeConfig([credentialsId: 'kubeconfig-circleguard']) {
                    sh 'kubectl rollout status deployment/${DEPLOYMENT_NAME} -n ${K8S_NAMESPACE} --timeout=180s'
                }
            }
        }
    }

    post {
        always {
            junit allowEmptyResults: true, testResults: 'services/circleguard-dashboard-service/build/test-results/**/*.xml'
        }
        failure {
            echo 'Pipeline failed for circleguard-dashboard-service'
        }
        success {
            echo '''
=============================================================
  circleguard-dashboard-service — deployed to circleguard-dev
=============================================================
  WHAT IT DOES
  ------------
  Exposes aggregated health-exposure analytics for admins.
  Applies a k-anonymity filter before surfacing any metric,
  so individual records are never revealed. Consumes spatial
  and health-status data from the promotion service.

  KEY ENDPOINTS
  -------------
  GET /api/v1/analytics/exposure        — exposure summary
  GET /api/v1/analytics/circles         — per-circle stats
  GET /api/v1/analytics/buildings       — per-building stats
  GET /api/v1/analytics/timeline        — daily trend data

  HOW TO ACCESS (dev)
  -------------------
  kubectl port-forward -n circleguard-dev svc/circleguard-dashboard 8084:8084
  → http://localhost:8084/swagger-ui.html
  → http://localhost:8084/api/v1/analytics/exposure
=============================================================
'''
        }
    }
}
