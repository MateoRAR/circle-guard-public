pipeline {
    agent any

    environment {
        DOCKER_REGISTRY  = 'kind-registry:5000'
        IMAGE_NAME       = 'circleguard/gateway-service'
        IMAGE_TAG        = 'dev'
        DEPLOYMENT_NAME  = 'circleguard-gateway'
        K8S_NAMESPACE    = 'circleguard-dev'
        K8S_DIR          = 'k8s/services/circleguard-gateway'
        GRADLE_TARGET    = ':services:circleguard-gateway-service'
        GRADLE_USER_HOME = '/var/jenkins_home/.gradle'
        PATH             = "/var/jenkins_home/bin:${env.PATH}"
    }

    stages {
        stage('Checkout') {
            steps {
                cleanWs()
                checkout scm
            }
        }

        stage('Build') {
            steps {
                sh './gradlew ${GRADLE_TARGET}:build -x test'
            }
        }

        stage('Unit Test') {
            steps {
                withCredentials([
                    string(credentialsId: 'jwt-secret', variable: 'JWT_SECRET'),
                    string(credentialsId: 'qr-secret',  variable: 'QR_SECRET')
                ]) {
                    sh './gradlew ${GRADLE_TARGET}:test'
                }
            }
        }

        stage('Docker Build') {
            steps {
                sh 'docker build --network=host -f services/circleguard-gateway-service/Dockerfile -t ${DOCKER_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG} .'
            }
        }

        stage('Docker Push') {
            steps {
                sh 'docker push ${DOCKER_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}'
            }
        }

        stage('Deploy Dev') {
            steps {
                withKubeConfig([credentialsId: 'kubeconfig-circleguard']) {
                    sh 'kubectl apply -k ${K8S_DIR}/ -n ${K8S_NAMESPACE}'
                    sh 'kubectl rollout restart deployment/${DEPLOYMENT_NAME} -n ${K8S_NAMESPACE}'
                }
            }
        }

        stage('Verify Rollout') {
            steps {
                withKubeConfig([credentialsId: 'kubeconfig-circleguard']) {
                    sh 'kubectl rollout status deployment/${DEPLOYMENT_NAME} -n ${K8S_NAMESPACE} --timeout=180s'
                }
            }
        }
    }

    post {
        always {
            junit allowEmptyResults: true, testResults: 'services/circleguard-gateway-service/build/test-results/**/*.xml'
        }
        failure {
            echo 'Pipeline failed for circleguard-gateway-service'
        }
        success {
            echo '''
=============================================================
  circleguard-gateway-service — deployed to circleguard-dev
=============================================================
  WHAT IT DOES
  ------------
  Physical gate validation service — the entry point for
  QR code scans at building access points. Verifies the
  signed QR token issued by the auth service, then signals
  the promotion service to record the circle entry/exit event.
  Coordinates with Redis for rate-limiting scan attempts.

  KEY ENDPOINTS
  -------------
  POST /api/v1/gate/validate           — validate a QR token scan
  GET  /api/v1/gate/status/{pointId}   — check gate/access-point status

  HOW TO ACCESS (dev)
  -------------------
  kubectl port-forward -n circleguard-dev svc/circleguard-gateway 8087:8087
  → http://localhost:8087/swagger-ui.html
  → POST http://localhost:8087/api/v1/gate/validate  body: {"token":"<qr-token>"}
=============================================================
'''
        }
    }
}
