pipeline {
    agent any

    environment {
        DOCKER_REGISTRY  = 'kind-registry:5000'
        IMAGE_NAME       = 'circleguard/auth-service'
        IMAGE_TAG        = 'dev'
        DEPLOYMENT_NAME  = 'circleguard-auth'
        K8S_NAMESPACE    = 'circleguard-dev'
        K8S_DIR          = 'k8s/services/circleguard-auth'
        GRADLE_TARGET    = ':services:circleguard-auth-service'
        GRADLE_USER_HOME = '/var/jenkins_home/.gradle'
        PATH             = "/var/jenkins_home/bin:${env.PATH}"
    }

    stages {
        stage('Checkout') {
            steps {
                cleanWs()
                checkout scm
            }
        }

        stage('Build') {
            steps {
                sh './gradlew ${GRADLE_TARGET}:build -x test'
            }
        }

        stage('Unit Test') {
            steps {
                withCredentials([
                    string(credentialsId: 'jwt-secret',      variable: 'JWT_SECRET'),
                    string(credentialsId: 'qr-secret',       variable: 'QR_SECRET'),
                    string(credentialsId: 'vault-secret',    variable: 'VAULT_SECRET'),
                    string(credentialsId: 'vault-salt',      variable: 'VAULT_SALT'),
                    string(credentialsId: 'vault-hash-salt', variable: 'VAULT_HASH_SALT')
                ]) {
                    sh './gradlew ${GRADLE_TARGET}:test'
                }
            }
        }

        stage('Docker Build') {
            steps {
                sh 'docker build --network=host -f services/circleguard-auth-service/Dockerfile -t ${DOCKER_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG} .'
            }
        }

        stage('Docker Push') {
            steps {
                sh 'docker push ${DOCKER_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}'
            }
        }

        stage('Deploy Dev') {
            steps {
                withKubeConfig([credentialsId: 'kubeconfig-circleguard']) {
                    sh 'kubectl apply -f ${K8S_DIR}/ -n ${K8S_NAMESPACE}'
                    sh 'kubectl rollout restart deployment/${DEPLOYMENT_NAME} -n ${K8S_NAMESPACE}'
                }
            }
        }

        stage('Verify Rollout') {
            steps {
                withKubeConfig([credentialsId: 'kubeconfig-circleguard']) {
                    sh 'kubectl rollout status deployment/${DEPLOYMENT_NAME} -n ${K8S_NAMESPACE} --timeout=180s'
                }
            }
        }
    }

    post {
        always {
            junit allowEmptyResults: true, testResults: 'services/circleguard-auth-service/build/test-results/**/*.xml'
        }
        failure {
            echo 'Pipeline failed for circleguard-auth-service'
        }
        success {
            echo '''
=============================================================
  circleguard-auth-service — deployed to circleguard-dev
=============================================================
  WHAT IT DOES
  ------------
  Authenticates users and issues signed JWT tokens with
  role-based permissions (ADMIN, GUARD, USER).
  Also generates short-lived QR tokens used by the gateway
  service to validate physical entry/exit events.

  KEY ENDPOINTS
  -------------
  POST /api/v1/auth/login          — username+password → JWT
  POST /api/v1/auth/refresh        — rotate access token
  POST /api/v1/auth/qr-token       — generate gate QR token
  GET  /api/v1/users               — list users (ADMIN only)
  POST /api/v1/users               — create user (ADMIN only)

  HOW TO ACCESS (dev)
  -------------------
  kubectl port-forward -n circleguard-dev svc/circleguard-auth 8180:8180
  → http://localhost:8180/swagger-ui.html
  → http://localhost:8180/api/v1/auth/login
=============================================================
'''
        }
    }
}
