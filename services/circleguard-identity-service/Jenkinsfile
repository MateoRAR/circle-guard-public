pipeline {
    agent any

    environment {
        DOCKER_REGISTRY   = 'kind-registry:5000'
        IMAGE_NAME        = 'circleguard/identity-service'
        IMAGE_TAG         = 'dev'
        DEPLOYMENT_NAME   = 'circleguard-identity'
        K8S_NAMESPACE     = 'circleguard-dev'
        K8S_DIR           = 'k8s/services/circleguard-identity'
        GRADLE_TARGET     = ':services:circleguard-identity-service'
        GRADLE_USER_HOME  = '/var/jenkins_home/.gradle'
        PATH              = "/var/jenkins_home/bin:${env.PATH}"
    }

    stages {
        stage('Checkout') {
            steps {
                cleanWs()
                checkout scm
            }
        }

        stage('Build') {
            steps {
                sh './gradlew ${GRADLE_TARGET}:build -x test'
            }
        }

        stage('Unit Test') {
            steps {
                withCredentials([
                    string(credentialsId: 'jwt-secret',      variable: 'JWT_SECRET'),
                    string(credentialsId: 'vault-secret',    variable: 'VAULT_SECRET'),
                    string(credentialsId: 'vault-salt',      variable: 'VAULT_SALT'),
                    string(credentialsId: 'vault-hash-salt', variable: 'VAULT_HASH_SALT')
                ]) {
                    sh './gradlew ${GRADLE_TARGET}:test'
                }
            }
        }

        stage('Docker Build') {
            steps {
                sh 'docker build --network=host -f services/circleguard-identity-service/Dockerfile -t ${DOCKER_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG} .'
            }
        }

        stage('Docker Push') {
            steps {
                sh 'docker push ${DOCKER_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}'
            }
        }

        stage('Deploy Dev') {
            steps {
                withKubeConfig([credentialsId: 'kubeconfig-circleguard']) {
                    sh 'kubectl apply -f ${K8S_DIR}/ -n ${K8S_NAMESPACE}'
                    sh 'kubectl rollout restart deployment/${DEPLOYMENT_NAME} -n ${K8S_NAMESPACE}'
                }
            }
        }

        stage('Verify Rollout') {
            steps {
                withKubeConfig([credentialsId: 'kubeconfig-circleguard']) {
                    sh 'kubectl rollout status deployment/${DEPLOYMENT_NAME} -n ${K8S_NAMESPACE} --timeout=180s'
                }
            }
        }
    }

    post {
        always {
            junit allowEmptyResults: true, testResults: 'services/circleguard-identity-service/build/test-results/**/*.xml'
        }
        failure {
            echo 'Pipeline failed for circleguard-identity-service'
        }
        success {
            echo '''
=============================================================
  circleguard-identity-service — deployed to circleguard-dev
=============================================================
  WHAT IT DOES
  ------------
  Privacy-preserving identity vault. Stores PII (name, email,
  document) encrypted at rest with AES-256 + per-field HMAC.
  Links anonymous participant UUIDs to real identities;
  lookups require the identity:lookup permission in the JWT.
  Audit events are emitted to Kafka on every access attempt.

  KEY ENDPOINTS
  -------------
  POST /api/v1/identities              — register an identity (returns UUID)
  GET  /api/v1/identities/{id}         — decrypt & return PII (identity:lookup)
  GET  /api/v1/identities/visitor      — create anonymous visitor token (public)
  GET  /api/v1/identities/map          — list UUID→alias mappings (public)

  HOW TO ACCESS (dev)
  -------------------
  kubectl port-forward -n circleguard-dev svc/circleguard-identity 8083:8083
  → http://localhost:8083/swagger-ui.html
  → http://localhost:8083/api/v1/identities/visitor
=============================================================
'''
        }
    }
}   