pipeline {
    agent any

    environment {
        DOCKER_REGISTRY  = 'kind-registry:5000'
        IMAGE_NAME       = 'circleguard/file-service'
        IMAGE_TAG        = 'dev'
        DEPLOYMENT_NAME  = 'circleguard-file'
        K8S_NAMESPACE    = 'circleguard-dev'
        K8S_DIR          = 'k8s/services/circleguard-file'
        GRADLE_TARGET    = ':services:circleguard-file-service'
        GRADLE_USER_HOME = '/var/jenkins_home/.gradle'
        PATH             = "/var/jenkins_home/bin:${env.PATH}"
    }

    stages {
        stage('Checkout') {
            steps {
                cleanWs()
                checkout scm
            }
        }

        stage('Build') {
            steps {
                sh './gradlew ${GRADLE_TARGET}:build -x test'
            }
        }

        stage('Unit Test') {
            steps {
                sh './gradlew ${GRADLE_TARGET}:test'
            }
        }

        stage('Docker Build') {
            steps {
                sh 'docker build --network=host -f services/circleguard-file-service/Dockerfile -t ${DOCKER_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG} .'
            }
        }

        stage('Docker Push') {
            steps {
                sh 'docker push ${DOCKER_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}'
            }
        }

        stage('Deploy Dev') {
            steps {
                withKubeConfig([credentialsId: 'kubeconfig-circleguard']) {
                    sh 'kubectl apply -f ${K8S_DIR}/ -n ${K8S_NAMESPACE}'
                    sh 'kubectl rollout restart deployment/${DEPLOYMENT_NAME} -n ${K8S_NAMESPACE}'
                }
            }
        }

        stage('Verify Rollout') {
            steps {
                withKubeConfig([credentialsId: 'kubeconfig-circleguard']) {
                    sh 'kubectl rollout status deployment/${DEPLOYMENT_NAME} -n ${K8S_NAMESPACE} --timeout=180s'
                }
            }
        }
    }

    post {
        always {
            junit allowEmptyResults: true, testResults: 'services/circleguard-file-service/build/test-results/**/*.xml'
        }
        failure {
            echo 'Pipeline failed for circleguard-file-service'
        }
        success {
            echo '''
=============================================================
  circleguard-file-service — deployed to circleguard-dev
=============================================================
  WHAT IT DOES
  ------------
  Handles multipart file uploads and serves stored files.
  Used by the form service to attach health certificates,
  PCR results, and other documents to health surveys.
  Files are stored on a persistent volume inside the cluster.

  KEY ENDPOINTS
  -------------
  POST   /api/v1/files/upload     — upload a file (multipart/form-data)
  GET    /api/v1/files/{fileId}   — download a stored file
  DELETE /api/v1/files/{fileId}   — delete a file

  HOW TO ACCESS (dev)
  -------------------
  kubectl port-forward -n circleguard-dev svc/circleguard-file 8085:8085
  → http://localhost:8085/swagger-ui.html
  → curl -F "file=@cert.pdf" http://localhost:8085/api/v1/files/upload
=============================================================
'''
        }
    }
}
