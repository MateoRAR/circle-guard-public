pipeline {
    agent any

    environment {
        DOCKER_REGISTRY  = 'kind-registry:5000'
        IMAGE_NAME       = 'circleguard/promotion-service'
        IMAGE_TAG        = 'dev'
        DEPLOYMENT_NAME  = 'circleguard-promotion'
        K8S_NAMESPACE    = 'circleguard-dev'
        K8S_DIR          = 'k8s/services/circleguard-promotion'
        GRADLE_TARGET    = ':services:circleguard-promotion-service'
        GRADLE_USER_HOME = '/var/jenkins_home/.gradle'
        PATH             = "/var/jenkins_home/bin:${env.PATH}"
    }

    stages {
        stage('Checkout') {
            steps {
                cleanWs()
                checkout scm
            }
        }

        stage('Build') {
            steps {
                sh './gradlew ${GRADLE_TARGET}:build -x test'
            }
        }

        stage('Unit Test') {
            steps {
                withCredentials([
                    string(credentialsId: 'jwt-secret', variable: 'JWT_SECRET')
                ]) {
                    sh './gradlew ${GRADLE_TARGET}:test'
                }
            }
        }

        stage('Docker Build') {
            steps {
                sh 'docker build --network=host -f services/circleguard-promotion-service/Dockerfile -t ${DOCKER_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG} .'
            }
        }

        stage('Docker Push') {
            steps {
                sh 'docker push ${DOCKER_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}'
            }
        }

        stage('Deploy Dev') {
            steps {
                withKubeConfig([credentialsId: 'kubeconfig-circleguard']) {
                    sh 'kubectl apply -k ${K8S_DIR}/ -n ${K8S_NAMESPACE}'
                    sh 'kubectl rollout restart deployment/${DEPLOYMENT_NAME} -n ${K8S_NAMESPACE}'
                }
            }
        }

        stage('Verify Rollout') {
            // Promotion has more infra deps (Neo4j, Kafka, Redis) so allow more time
            steps {
                withKubeConfig([credentialsId: 'kubeconfig-circleguard']) {
                    sh 'kubectl rollout status deployment/${DEPLOYMENT_NAME} -n ${K8S_NAMESPACE} --timeout=300s'
                }
            }
        }
    }

    post {
        always {
            junit allowEmptyResults: true, testResults: 'services/circleguard-promotion-service/build/test-results/**/*.xml'
        }
        failure {
            echo 'Pipeline failed for circleguard-promotion-service'
        }
        success {
            echo '''
=============================================================
  circleguard-promotion-service — deployed to circleguard-dev
=============================================================
  WHAT IT DOES
  ------------
  Core spatial and epidemiological graph engine. Manages the
  building/floor/access-point hierarchy in PostgreSQL and the
  encounter proximity graph in Neo4j. Tracks health status
  lifecycle (healthy → exposed → confirmed → recovered) and
  propagates exposure notifications via Kafka. Also handles
  BLE mesh session handshakes and circle auto-detection.
  Infra deps: PostgreSQL, Neo4j, Redis (cache), Kafka.

  KEY ENDPOINTS
  -------------
  GET  /api/v1/buildings                 — list buildings
  GET  /api/v1/buildings/{id}/floors     — floors in a building
  POST /api/v1/circles                   — create/join a circle
  POST /api/v1/encounters                — record a mesh encounter
  GET  /api/v1/health-status/{userId}    — current health status
  PUT  /api/v1/health-status/{userId}    — update health status
  GET  /api/v1/mesh/stats                — live mesh statistics

  HOW TO ACCESS (dev)
  -------------------
  kubectl port-forward -n circleguard-dev svc/circleguard-promotion 8088:8088
  → http://localhost:8088/swagger-ui.html
  → http://localhost:8088/api/v1/buildings
=============================================================
'''
        }
    }
}
